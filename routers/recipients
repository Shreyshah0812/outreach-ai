from fastapi import APIRouter, Depends, HTTPException, BackgroundTasks
from sqlalchemy.orm import Session
from typing import List
from datetime import datetime
import asyncio
import time

from models.database import get_db
from models.db import Recipient, Campaign
from models.schemas import RecipientCreate, RecipientOut, RecipientUpdate, BulkRecipientCreate
from services.research import research_recipient
from services.email_generator import generate_email
from services.email_sender import send_email_async

router = APIRouter(prefix="/api/recipients", tags=["recipients"])


@router.post("", response_model=RecipientOut)
def add_recipient(data: RecipientCreate, db: Session = Depends(get_db)):
    campaign = db.query(Campaign).filter(Campaign.id == data.campaign_id).first()
    if not campaign:
        raise HTTPException(status_code=404, detail="Campaign not found")

    recipient = Recipient(**data.model_dump())
    db.add(recipient)
    db.commit()
    db.refresh(recipient)
    return recipient


@router.post("/bulk", response_model=List[RecipientOut])
def add_recipients_bulk(data: BulkRecipientCreate, db: Session = Depends(get_db)):
    created = []
    for r in data.recipients:
        recipient = Recipient(**r.model_dump())
        db.add(recipient)
        created.append(recipient)
    db.commit()
    for r in created:
        db.refresh(r)
    return created


@router.get("/campaign/{campaign_id}", response_model=List[RecipientOut])
def list_recipients(campaign_id: int, db: Session = Depends(get_db)):
    return db.query(Recipient).filter(Recipient.campaign_id == campaign_id).all()


@router.get("/{recipient_id}", response_model=RecipientOut)
def get_recipient(recipient_id: int, db: Session = Depends(get_db)):
    r = db.query(Recipient).filter(Recipient.id == recipient_id).first()
    if not r:
        raise HTTPException(status_code=404, detail="Recipient not found")
    return r


@router.patch("/{recipient_id}", response_model=RecipientOut)
def update_recipient(recipient_id: int, data: RecipientUpdate, db: Session = Depends(get_db)):
    r = db.query(Recipient).filter(Recipient.id == recipient_id).first()
    if not r:
        raise HTTPException(status_code=404, detail="Recipient not found")
    for field, value in data.model_dump(exclude_unset=True).items():
        setattr(r, field, value)
    db.commit()
    db.refresh(r)
    return r


@router.delete("/{recipient_id}")
def delete_recipient(recipient_id: int, db: Session = Depends(get_db)):
    r = db.query(Recipient).filter(Recipient.id == recipient_id).first()
    if not r:
        raise HTTPException(status_code=404, detail="Recipient not found")
    db.delete(r)
    db.commit()
    return {"success": True}


# ─── Research ────────────────────────────────────────────────

@router.post("/{recipient_id}/research", response_model=RecipientOut)
def run_research(recipient_id: int, background_tasks: BackgroundTasks, db: Session = Depends(get_db)):
    r = db.query(Recipient).filter(Recipient.id == recipient_id).first()
    if not r:
        raise HTTPException(status_code=404, detail="Recipient not found")

    r.research_status = "researching"
    db.commit()

    background_tasks.add_task(_do_research, recipient_id)

    db.refresh(r)
    return r


def _do_research(recipient_id: int):
    from models.database import SessionLocal
    db = SessionLocal()
    try:
        r = db.query(Recipient).filter(Recipient.id == recipient_id).first()
        if not r:
            return
        context = research_recipient(r.name, r.company, r.role, r.linkedin_url)
        r.research_context = context
        r.research_status = "done"
        db.commit()
    except Exception as e:
        r.research_status = "failed"
        r.error_message = str(e)
        db.commit()
    finally:
        db.close()


# ─── Generate ────────────────────────────────────────────────

@router.post("/{recipient_id}/generate", response_model=RecipientOut)
def run_generate(recipient_id: int, background_tasks: BackgroundTasks, db: Session = Depends(get_db)):
    r = db.query(Recipient).filter(Recipient.id == recipient_id).first()
    if not r:
        raise HTTPException(status_code=404, detail="Recipient not found")

    if r.research_status != "done":
        raise HTTPException(status_code=400, detail="Research must complete before generating email")

    r.generation_status = "generating"
    db.commit()

    background_tasks.add_task(_do_generate, recipient_id)

    db.refresh(r)
    return r


def _do_generate(recipient_id: int):
    from models.database import SessionLocal
    db = SessionLocal()
    try:
        r = db.query(Recipient).filter(Recipient.id == recipient_id).first()
        if not r:
            return
        campaign = r.campaign

        subject, body, score = generate_email(
            recipient_name=r.name,
            recipient_email=r.email,
            recipient_company=r.company,
            recipient_role=r.role,
            research_context=r.research_context or "",
            resume_text=campaign.resume_text or "",
            job_description=campaign.job_description or "",
            tone=campaign.tone,
        )

        r.generated_subject = subject
        r.generated_body = body
        r.personalization_score = score
        r.generation_status = "done"
        db.commit()
    except Exception as e:
        r.generation_status = "failed"
        r.error_message = str(e)
        db.commit()
    finally:
        db.close()


# ─── Send ────────────────────────────────────────────────────

@router.post("/{recipient_id}/send", response_model=RecipientOut)
async def send_to_recipient(recipient_id: int, db: Session = Depends(get_db)):
    r = db.query(Recipient).filter(Recipient.id == recipient_id).first()
    if not r:
        raise HTTPException(status_code=404, detail="Recipient not found")

    if r.generation_status != "done":
        raise HTTPException(status_code=400, detail="Email must be generated before sending")

    try:
        await send_email_async(
            to_email=r.email,
            subject=r.generated_subject,
            body=r.generated_body,
            from_name=r.campaign.sender_email,
        )
        r.send_status = "sent"
        r.sent_at = datetime.utcnow()
        db.commit()
    except Exception as e:
        r.send_status = "failed"
        r.error_message = str(e)
        db.commit()
        raise HTTPException(status_code=500, detail=str(e))

    db.refresh(r)
    return r


@router.post("/campaign/{campaign_id}/send-all")
async def send_all(campaign_id: int, db: Session = Depends(get_db)):
    campaign = db.query(Campaign).filter(Campaign.id == campaign_id).first()
    if not campaign:
        raise HTTPException(status_code=404, detail="Campaign not found")

    recipients = db.query(Recipient).filter(
        Recipient.campaign_id == campaign_id,
        Recipient.generation_status == "done",
        Recipient.send_status == "queued",
    ).all()

    results = {"sent": [], "failed": []}
    delay = campaign.send_delay_seconds or 0

    for i, r in enumerate(recipients):
        if i > 0 and delay > 0:
            await asyncio.sleep(delay)
        try:
            await send_email_async(
                to_email=r.email,
                subject=r.generated_subject,
                body=r.generated_body,
                from_name=campaign.sender_email,
            )
            r.send_status = "sent"
            r.sent_at = datetime.utcnow()
            results["sent"].append(r.email)
        except Exception as e:
            r.send_status = "failed"
            r.error_message = str(e)
            results["failed"].append({"email": r.email, "error": str(e)})
        db.commit()

    return results
