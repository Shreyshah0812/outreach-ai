from pydantic import BaseModel, EmailStr
from typing import Optional, List
from datetime import datetime


# ─── Campaign ────────────────────────────────────────────────

class CampaignCreate(BaseModel):
    name: str
    sender_email: str
    tone: str = "Concise & Direct"
    send_delay_seconds: int = 0
    job_description: Optional[str] = None


class CampaignOut(BaseModel):
    id: int
    name: str
    sender_email: str
    tone: str
    send_delay_seconds: int
    job_description: Optional[str]
    resume_text: Optional[str]
    created_at: datetime

    class Config:
        from_attributes = True


# ─── Recipient ───────────────────────────────────────────────

class RecipientCreate(BaseModel):
    campaign_id: int
    name: str
    email: str
    company: Optional[str] = None
    role: Optional[str] = None
    linkedin_url: Optional[str] = None


class RecipientOut(BaseModel):
    id: int
    campaign_id: int
    name: str
    email: str
    company: Optional[str]
    role: Optional[str]
    linkedin_url: Optional[str]
    research_status: str
    research_context: Optional[str]
    generation_status: str
    generated_subject: Optional[str]
    generated_body: Optional[str]
    personalization_score: Optional[float]
    send_status: str
    sent_at: Optional[datetime]
    error_message: Optional[str]
    created_at: datetime

    class Config:
        from_attributes = True


class RecipientUpdate(BaseModel):
    generated_subject: Optional[str] = None
    generated_body: Optional[str] = None


# ─── Misc ────────────────────────────────────────────────────

class StatusResponse(BaseModel):
    success: bool
    message: str


class BulkRecipientCreate(BaseModel):
    recipients: List[RecipientCreate]
